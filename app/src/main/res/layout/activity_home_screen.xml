<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeScreen">

    <TextView
        android:id="@+id/tvH"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="135dp"
        android:layout_marginTop="31dp"
        android:gravity="center"
        android:text="Home"
        android:textSize="34sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/etSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:layout_marginEnd="33dp"
        android:ems="10"
        android:inputType="text"
        android:text="Search"
        app:layout_constraintEnd_toEndOf="@+id/search"
        app:layout_constraintTop_toBottomOf="@+id/tvH"
        tools:ignore="MissingConstraints" />

    <SearchView
        android:id="@+id/search"
        android:layout_width="55dp"
        android:layout_height="42dp"
        android:layout_marginStart="39dp"
        android:layout_marginTop="5dp"
        app:layout_constraintStart_toEndOf="@+id/tvH"
        app:layout_constraintTop_toTopOf="@+id/etSearch"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/etText13"
        android:layout_width="442dp"
        android:layout_height="46dp"
        android:layout_marginTop="36dp"
        android:layout_marginBottom="50dp"
        android:ems="10"
        android:inputType="text"
        app:layout_constraintBottom_toTopOf="@+id/btnReport"
        app:layout_constraintTop_toTopOf="@+id/btn3"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="-25dp" />

    <Button
        android:id="@+id/btn3"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginBottom="64dp"
        android:background="@drawable/circular_button"
        android:gravity="center"
        android:includeFontPadding="false"
        android:padding="0dp"
        android:text="+"
        android:textAlignment="center"
        android:textColor="#F4D9D9"
        android:textSize="24sp"
        app:layout_constraintBottom_toTopOf="@+id/btnAdoption"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="MissingConstraints" />

    <Button
        android:id="@+id/btnReport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Report"
        app:layout_constraintBaseline_toBaselineOf="@+id/btnLocation"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="29dp"
        android:layout_marginBottom="88dp"
        android:text="Location"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btnReport" />

    <Button
        android:id="@+id/btnAdoption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="37dp"
        android:text="Adoption"
        app:layout_constraintBaseline_toBaselineOf="@+id/btnLocation"
        app:layout_constraintEnd_toEndOf="parent" />

    <ListView
        android:id="@+id/lstTasks"
        android:layout_width="0dp"
        android:layout_height="328dp"
        android:layout_marginBottom="272dp"
        android:background="#C5C7CB"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>